@page
@model AutoGarageManager.Pages.Admin.RemindersModel
@{
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Nhắc Bảo Dưỡng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0">Nhắc Bảo Dưỡng</h2>
    <a class="btn btn-dark" asp-page="" asp-route-create="true">Thêm nhắc mới</a>
</div>

@if (Model.IsEditing)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h5 class="card-title">@((Model.InputReminder.Id == 0) ? "Tạo nhắc mới" : "Chỉnh sửa nhắc")</h5>
            <form method="post" asp-page-handler="@(Model.InputReminder.Id == 0 ? "Create" : "Edit")"
                  asp-route-id="@Model.InputReminder.Id">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Xe</label>
                        <select asp-for="InputReminder.VehicleId" class="form-select">
                            <option value="">-- Chọn xe --</option>
                            @foreach (var vehicle in Model.Vehicles)
                            {
                                if (vehicle.Id == Model.InputReminder.VehicleId)
                                {
                                    <option value="@vehicle.Id" selected>@vehicle.LicensePlate - @vehicle.Model</option>
                                }
                                else
                                {
                                    <option value="@vehicle.Id">@vehicle.LicensePlate - @vehicle.Model</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="InputReminder.VehicleId" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Ngày nhắc</label>
                        <input asp-for="InputReminder.ReminderDate" type="date" class="form-control" />
                        <span asp-validation-for="InputReminder.ReminderDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Tiêu đề</label>
                        <input asp-for="InputReminder.Title" class="form-control" />
                        <span asp-validation-for="InputReminder.Title" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Đã hoàn thành</label>
                        <input asp-for="InputReminder.IsCompleted" type="checkbox" class="form-check-input" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Nội dung</label>
                        <textarea asp-for="InputReminder.Message" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="InputReminder.Message" class="text-danger"></span>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Lưu</button>
                    <a class="btn btn-secondary" href="@Url.Page(null)">Hủy</a>
                </div>
            </form>
        </div>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Xe</th>
                    <th>Khách hàng</th>
                    <th>Ngày nhắc</th>
                    <th>Tiêu đề</th>
                    <th>Trạng thái</th>
                    <th style="width: 160px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reminder in Model.Reminders)
                {
                    <tr>
                        <td>@reminder.Vehicle?.LicensePlate</td>
                        <td>@reminder.Vehicle?.Customer?.FullName</td>
                        <td>@reminder.ReminderDate.ToString("yyyy-MM-dd")</td>
                        <td>@reminder.Title</td>
                        <td>@(reminder.IsCompleted ? "Hoàn thành" : "Chưa")</td>
                        <td>
                            <a class="text-decoration-none" asp-page="" asp-route-editId="@reminder.Id">Sửa</a>
                            <span class="mx-1">|</span>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@reminder.Id" class="d-inline">
                                <button type="submit" class="btn btn-link p-0 text-danger"
                                        onclick="return confirm('Bạn có chắc muốn xóa?');">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Reminders.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">Chưa có nhắc bảo dưỡng</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}