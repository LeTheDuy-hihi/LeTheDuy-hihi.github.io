@page
@model AutoGarageManager.Pages.Admin.ServicesModel
@{
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Dịch Vụ";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0">Dịch Vụ</h2>
    <a class="btn btn-dark" asp-page="" asp-route-create="true">+ Thêm Dịch Vụ</a>
</div>

@if (Model.IsEditing)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h5 class="card-title">@((Model.InputService.Id == 0) ? "Tạo dịch vụ" : "Chỉnh sửa dịch vụ")</h5>
            <form method="post" asp-page-handler="@(Model.InputService.Id == 0 ? "Create" : "Edit")"
                  asp-route-id="@Model.InputService.Id">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Tên dịch vụ</label>
                        <input asp-for="InputService.Name" class="form-control" />
                        <span asp-validation-for="InputService.Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Thời lượng (phút)</label>
                        <input asp-for="InputService.EstimatedDuration" class="form-control" />
                        <span asp-validation-for="InputService.EstimatedDuration" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Giá</label>
                        <input asp-for="InputService.Price" class="form-control" />
                        <span asp-validation-for="InputService.Price" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Mô tả</label>
                        <textarea asp-for="InputService.Description" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="InputService.Description" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Lưu</button>
                    <a class="btn btn-secondary" href="@Url.Page(null)">Hủy</a>
                </div>
            </form>
        </div>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Tên dịch vụ</th>
                    <th>Mô tả</th>
                    <th>Giá</th>
                    <th style="width: 160px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var service in Model.Services)
                {
                    <tr>
                        <td>@service.Name</td>
                        <td>@service.Description</td>
                        <td>@service.Price.ToString("N0")₫</td>
                        <td>
                            <a class="text-decoration-none" asp-page="" asp-route-editId="@service.Id">Sửa</a>
                            <span class="mx-1">|</span>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@service.Id" class="d-inline">
                                <button type="submit" class="btn btn-link p-0 text-danger"
                                        onclick="return confirm('Bạn có chắc muốn xóa?');">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Services.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">Chưa có dịch vụ nào</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}